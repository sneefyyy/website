{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "GENERATE_SOURCEMAP": "false"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ],
  "redirects": [
    { "source": "/latent-space", "destination": "/projects/latent-space/index.html", "permanent": false },
    { "source": "/synesthesia-machine", "destination": "/projects/latent-space/index.html", "permanent": false }
  ],
  "functions": {
    "api/**/*.py": {
      "memory": 1024,
      "maxDuration": 60,
      "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,__pycache__/**,.venv/**,*.md}"
    }
  }
}
